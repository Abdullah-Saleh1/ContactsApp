<Window x:Class="ContactApp_PresentationLayer.AddEditContact"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContactApp_PresentationLayer"
        mc:Ignorable="d"
        Title="Add/Edit Contact"
        Height="700"
        ResizeMode="NoResize"
        Width="450" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B0B10" Offset="0.0"/>
            <GradientStop Color="#141424" Offset="0.5"/>
            <GradientStop Color="#0D0D14" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#161624"/>
            <Setter Property="Foreground" Value="#E2E2E9"/>
            <Setter Property="BorderBrush" Value="#2D2D44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                      BorderBrush="{TemplateBinding BorderBrush}" 
                                      BorderThickness="{TemplateBinding BorderThickness}" 
                                      Background="{TemplateBinding Background}" 
                                      Grid.Column="2" 
                                      Focusable="false"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                      ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <TextBlock Text="▼" Foreground="#BABDC2" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#1C1C2D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,3,30,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#161624" BorderThickness="1" BorderBrush="#2D2D44" CornerRadius="4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#161624"/>
            <Setter Property="Foreground" Value="#E2E2E9"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#131322"/>
            <Setter Property="BorderBrush" Value="#252538"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E2E2E9"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Background="Transparent">
        <TextBlock Text="Contact Details" x:Name="txtContactDetails" FontWeight="Bold" FontSize="24" 
                   Margin="0, 20, 0, 10" HorizontalAlignment="Center" Foreground="#E2E2E9"/>

        <Grid Margin="30,10,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Contact ID:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#E2E2E9"/>
            <TextBox Margin="10" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtContactID" Height="30" 
                     VerticalContentAlignment="Center" Background="#FF0C0C15" Foreground="#5C5C7A" BorderBrush="#2D2D44"
                     IsReadOnly="True"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="First Name:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <TextBox Margin="10" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtFirstName" Height="30" VerticalContentAlignment="Center" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Name:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <TextBox Margin="10" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtLastName" Height="30" VerticalContentAlignment="Center" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <TextBox Margin="10" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtEmail" Height="30" VerticalContentAlignment="Center" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <TextBox Margin="10" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtPhone" Height="30" VerticalContentAlignment="Center" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <TextBox Margin="10" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtAddress" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Birthday:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <xctk:DateTimePicker Margin="10" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" x:Name="dtpDateOfBirth" Height="30"
                     Format="Custom" 
                     FormatString="MM/dd/yyyy hh:mm tt" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Country:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#E2E2E9"/>
            <ComboBox Margin="10" x:Name="CountriesComboBox" DisplayMemberPath="CountryName" SelectedValuePath="CountryID" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Height="30" Background="#161624" Foreground="#E2E2E9" BorderBrush="#2D2D44"/>

            <Image Grid.Row="8" Grid.Column="1" x:Name="imgContact" Width="80" Height="80" Stretch="Uniform" Margin="5"/>
            <Button Grid.Row="8" Grid.Column="0" x:Name="btnSetImage" Style="{StaticResource btn_crud}" Height="40" Width="Auto" Click="btnSetImage_Click">Set Image</Button>
            <Button x:Name="btnRemoveImage" Grid.Column="2" Grid.Row="8" Style="{StaticResource btn_crud}" Height="40" Width="40" Visibility="Hidden" Click="btnRemoveImage_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✖" Margin="0,0,5,0"/>
                </StackPanel>
            </Button>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 5, 0, 20">
            <Button Content="Save" Command="{Binding SaveCommand}" x:Name="btnSave" Style="{StaticResource btn_crud}" Width="110" Height="35" Margin="5" Click="btnSave_Click"/>
            <Button Content="Cancel" Command="{Binding CloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}" x:Name="btnCancel" Style="{StaticResource btn_crud}" Width="110" Height="35" Click="btnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>